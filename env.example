# Copy to ".env" in this folder (same folder as app.py).
# Flask loads it automatically if python-dotenv is installed.

YOUTUBE_API_KEY=

# Google sign-in (Flask OAuth — not Clerk)
# Redirect URI must match EXACTLY what you set in Google Cloud (including port).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/auth/google/callback

# Optional
# APP_SECRET=change-me-for-production
# APP_HOST=127.0.0.1
# APP_PORT=8080
